{{- /* Dispatch syntax depends on the config dialect: with hyprland.lua present
       (resolved at chezmoi-apply time), hyprctl dispatch args are Lua
       expressions; classic `dpms on/off` fails there. */ -}}
{{- $dpmsOn := "hyprctl dispatch dpms on" }}
{{- $dpmsOff := "hyprctl dispatch dpms off" }}
{{- if stat (joinPath .chezmoi.homeDir ".config/hypr/hyprland.lua") }}
{{- $dpmsOn = `hyprctl dispatch "hl.dsp.dpms({ action = 'on' })"` }}
{{- $dpmsOff = `hyprctl dispatch "hl.dsp.dpms({ action = 'off' })"` }}
{{- end }}
general {
  after_sleep_cmd={{ $dpmsOn }}
  lock_cmd=hyprlock
}

listener {
  on-timeout=loginctl lock-session
  timeout=180 # 3 minutes
}

listener {
  on-resume={{ $dpmsOn }}
  on-timeout={{ $dpmsOff }}
  timeout=240 # 4 minutes
  # timeout=24
}

listener {
  on-timeout=systemctl suspend
  timeout=540 # 9 minutes
  # timeout=54
}
