#!/bin/bash
# FAST: grim → PPM (uncompressed) → satty (HW accel) → clipboard
# Config: ~/.config/satty/config.toml

# Pre-create screenshot directory to avoid any mkdir overhead
mkdir -p ~/Pictures/Screenshots

# Optimized pipeline: uncompressed PPM format, config-driven satty
grim -g "$(slurp -d)" -t ppm - | satty --filename -