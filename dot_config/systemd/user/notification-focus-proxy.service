[Unit]
Description=Notification focus proxy (bring sender to front on click)
PartOf=graphical-session.target
After=graphical-session.target swaync.service

[Service]
Type=simple
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=%t/bus
ExecStart=%h/.local/bin/notification-focus-proxy
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
