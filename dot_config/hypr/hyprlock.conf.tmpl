# Import lmtt-generated Material You colors
source = ~/.config/hypr/lmtt-hyprlock-colors.conf

background {
    monitor =
    path = {{ .wallpaper }}
    color = $surface_rgba

    blur_passes = 3
    blur_size = 8
    noise = 0.01
    contrast = 1.0
    brightness = 0.8
    vibrancy = 0.2
    vibrancy_darkness = 0.0
}

# Time - floating with shadow (white for wallpaper legibility)
label {
    monitor =
    text = $TIME
    text_align = center
    color = rgba(255, 255, 255, 0.95)
    font_size = 86
    font_family = Noto Sans Light

    position = 0, 180
    halign = center
    valign = center

    shadow_passes = 3
    shadow_size = 5
    shadow_color = rgba(0, 0, 0, 0.8)
}

# Date - floating with shadow (white for wallpaper legibility)
label {
    monitor =
    text = cmd[update:60000] date +"%A, %B %d"
    text_align = center
    color = rgba(255, 255, 255, 0.85)
    font_size = 16
    font_family = Noto Sans

    position = 0, 110
    halign = center
    valign = center

    shadow_passes = 2
    shadow_size = 3
    shadow_color = rgba(0, 0, 0, 0.6)
}

# Frosted glass panel behind input
shape {
    monitor =
    size = 300, 140
    color = $surface_container_rgba
    rounding = 20
    border_size = 1
    border_color = $surface_dim_rgba

    position = 0, -110
    halign = center
    valign = center

    shadow_passes = 3
    shadow_size = 10
    shadow_color = rgba(0, 0, 0, 0.5)
}

# Greeting
label {
    monitor =
    text = Welcome back, $USER
    text_align = center
    color = $on_surface
    font_size = 16
    font_family = Noto Sans

    position = 0, -85
    halign = center
    valign = center
}

input-field {
    monitor =
    size = 260, 45
    outline_thickness = 0
    dots_size = 0.25
    dots_spacing = 0.2
    dots_center = true
    dots_rounding = -1
    outer_color = rgba(255, 255, 255, 0.0)
    inner_color = $surface_dim_rgba
    font_color = $on_surface
    fade_on_empty = true
    fade_timeout = 1500
    placeholder_text =
    hide_input = false
    rounding = 12
    check_color = $primary
    fail_color = $error
    fail_text = <i>$FAIL</i>
    fail_timeout = 2000
    fail_transition = 200
    capslock_color = rgba(255, 200, 0, 0.8)
    numlock_color = -1
    bothlock_color = -1
    invert_numlock = false
    swap_font_color = false

    position = 0, -135
    halign = center
    valign = center
}
