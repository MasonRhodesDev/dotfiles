#!/usr/bin/env bash
# Event-driven Claude activity watcher for WezTerm
# Auto-detects which session file belongs to this Claude session by watching for writes

# Only run in Claude sessions
[[ "${CLAUDECODE:-0}" != "1" ]] && exit 0

TTY_DEVICE="${1:-/dev/tty}"  # Terminal device to write OSC sequences to
CLAUDE_PPID="${2:-$$}"       # Parent PID to identify this session
STATUS_FILE="/tmp/claude-activity-$$"
MARKER_FILE="/tmp/claude-session-$CLAUDE_PPID"
PROJECTS_DIR="$HOME/.claude/projects/-home-mason"

# Cleanup on exit
trap "rm -f '$STATUS_FILE' '$MARKER_FILE'" EXIT

# Function to extract activity from session file
extract_activity() {
    local session_file="$1"
    tac "$session_file" | \
        jq -r 'select(.message.role=="user" and (.message.content | type) == "string") | .message.content' 2>/dev/null | \
        head -n 1 | \
        head -c 40 || true
}

# Auto-detect which session file belongs to this Claude session
# Strategy: Watch the projects directory and identify the first .jsonl file that gets modified
# This will be our session file since Claude writes to it when the session starts or when messages are sent
SESSION_FILE=""

# Check if we already have a marker file with the session file
if [[ -f "$MARKER_FILE" ]]; then
    SESSION_FILE=$(cat "$MARKER_FILE" 2>/dev/null)
    # Verify it still exists
    if [[ ! -f "$SESSION_FILE" ]]; then
        SESSION_FILE=""
    fi
fi

# If we don't have a session file yet, watch for the first modification
if [[ -z "$SESSION_FILE" ]] && command -v inotifywait >/dev/null 2>&1; then
    # Watch the directory for modifications (no timeout - wait for first interaction)
    # The first non-agent .jsonl file that gets modified is our session file
    inotifywait -q -e modify,close_write --format '%w%f' "$PROJECTS_DIR" 2>/dev/null | \
        while read -r modified_file; do
            if [[ "$modified_file" == *.jsonl ]] && [[ "$modified_file" != *agent-* ]] && [[ -f "$modified_file" ]]; then
                SESSION_FILE="$modified_file"
                echo "$SESSION_FILE" > "$MARKER_FILE"
                break
            fi
        done
fi

# If still no session file (shouldn't happen), exit gracefully
if [[ -z "$SESSION_FILE" ]] || [[ ! -f "$SESSION_FILE" ]]; then
    exit 0
fi
if [[ -n "$SESSION_FILE" ]] && [[ -f "$SESSION_FILE" ]]; then
    ACTIVITY=$(extract_activity "$SESSION_FILE")

    # If no activity found (new/empty session), use empty string
    # This will make WezTerm show just "Claude" without activity text
    if [[ -z "$ACTIVITY" ]]; then
        ACTIVITY=""
    fi

    echo "$ACTIVITY" > "$STATUS_FILE"

    # Send initial OSC sequence to WezTerm (write to terminal device)
    # Send even if empty to clear any previous activity
    printf '\033]1337;SetUserVar=CLAUDE_ACTIVITY=%s\007' "$(echo -n "$ACTIVITY" | base64)" > "$TTY_DEVICE" 2>/dev/null
fi

# Watch for changes to the session file
if [[ -n "$SESSION_FILE" ]] && command -v inotifywait >/dev/null 2>&1; then
    inotifywait -m -e modify "$SESSION_FILE" 2>/dev/null | while read -r; do
        ACTIVITY=$(extract_activity "$SESSION_FILE")

        # Always update, even if empty (to clear stale activity)
        echo "$ACTIVITY" > "$STATUS_FILE"

        # Send OSC sequence to WezTerm to update status (write to terminal device)
        printf '\033]1337;SetUserVar=CLAUDE_ACTIVITY=%s\007' "$(echo -n "$ACTIVITY" | base64)" > "$TTY_DEVICE" 2>/dev/null
    done
fi
