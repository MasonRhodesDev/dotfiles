# lmtt (Linux Matugen Theme Toggle) - Generated files
# All files generated by the theme system are prefixed with 'lmtt-'
**/lmtt-*

# Old software installers (migrated to run_after scripts)
software_installers/
software_installers.backup-*/

# Installation logs
**/*.log

# Plan files
.plans/
CURRENT_PLAN.md

# Test infrastructure
tests/
.github/

# Python cache
**/__pycache__/
**/*.pyc
.config/fish/fish_variables

# Chezmoi Agent files
AGENTS.md
CLAUDE.md

# Beads issue tracking (stays in repo, not applied to home)
.beads/

# Git configuration (stays in repo)
.gitattributes

# btop rewrites its own config on startup (version line, boolean casing) so
# tracking it just produces churn we'd never apply back.
.config/btop/btop.conf

# hyprstate manages this symlink at runtime based on connected monitors.
# Tracking it would pin the wrong profile on other machines.
.config/hypr/profiles/.active.conf

# Work-only: Claude templates (ticket creation, etc.)
{{ if not .is_work }}
.claude/templates
{{ end }}
