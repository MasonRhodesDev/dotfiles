#!/bin/bash
# Ultra-fast screenshot with satty annotation

# Quick screen freeze and selection
hyprpicker -r -z &
FREEZE_PID=$!
sleep 0.02

SELECTION=$(slurp -d 2>/dev/null)
SLURP_EXIT=$?
kill "$FREEZE_PID" 2>/dev/null || true

[ $SLURP_EXIT -ne 0 ] && exit 1
[ -z "$SELECTION" ] && exit 1

mkdir -p ~/Pictures/Screenshots

# Launch satty with the screenshot
grim -g "$SELECTION" - | satty \
    --filename - \
    --output-filename "~/Pictures/Screenshots/snip-%Y-%m-%d_%H-%M-%S.png" \
    --early-exit \
    --copy-command wl-copy \
    --initial-tool brush