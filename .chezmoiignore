# lmtt (Linux Matugen Theme Toggle) - Generated files
# All files generated by the theme system are prefixed with 'lmtt-'
**/lmtt-*

# Old software installers (migrated to run_after scripts)
software_installers/
software_installers.backup-*/

# Installation logs
**/*.log

# Plan files
.plans/
CURRENT_PLAN.md

# Test infrastructure
tests/
.github/

# Python cache
**/__pycache__/
**/*.pyc
.config/fish/fish_variables

# Chezmoi Agent files
AGENTS.md
CLAUDE.md

# Repo documentation (stays in repo, not deployed to home)
README.md
LICENSE
docs/

# Repo tooling (stays in repo, not deployed to home)
.githooks
.githooks/**
.gitleaks.toml

# Beads issue tracking (stays in repo, not applied to home)
.beads/

# Git configuration (stays in repo)
.gitattributes

# btop rewrites its own config on startup (version line, boolean casing) so
# tracking it just produces churn we'd never apply back.
.config/btop/btop.conf

# hyprstate manages this symlink at runtime based on connected monitors.
# Tracking it would pin the wrong profile on other machines.
.config/hypr/profiles/.active.conf

# lmtt regenerates this on every theme switch from the embedded template in
# .config/lmtt/modules/mako.toml — that .toml is the source of truth.
.config/mako/config

# Claude templates live in the private work overlay repo (deployed on work
# machines by run_onchange_after_35-sync-work-overlay), never in this public
# repo — so chezmoi must not manage this path on any machine.
.claude/templates

# App-owned settings: Claude Code and Zed rewrite these constantly (model
# changes, plugin toggles, panel layout), so managing them is perpetual drift.
.claude/settings.json
.config/zed/settings.json

# Gaming/Steam: personal machines only. The bp-game-focus.service unit is
# already gated inside its template; these gate the rest.
{{ if .is_work }}
.config/hypr/profiles/lg-tv.conf
.config/hypr/scripts/bp-game-focus.py
.config/hypr/scripts/steam-clean-shutdown.sh
.config/systemd/user/app-.scope.d
.config/systemd/user/app-.scope.d/**
.config/systemd/user/steam-clean-shutdown.service
.config/environment.d/gaming.conf
.local/bin/steam-set-launch-options
.local/share/notes
.local/share/notes/**
{{ end }}

# Work app entries (easytether stays shared — used on both machines)
{{ if not .is_work }}
.local/share/applications/slack.desktop
.local/share/applications/clickup-icon.png
{{ end }}

# Fresh-machine bootstrap (run from curl, stays in repo)
bootstrap.sh
