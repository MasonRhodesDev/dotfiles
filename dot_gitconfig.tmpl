[user]
    name = {{ .identity.name }}
    email = {{ .identity.email }}

[credential]
    credentialStore = secretservice

[credential "https://dev.azure.com"]
    useHttpPath = true

[push]
    autoSetupRemote = true
[init]
        defaultBranch = main

[alias]
	commit-gen = !git-commit-gen
	cg = "!f() { MSG=$(git-commit-gen) && git commit -F - <<< \"$MSG\"; }; f"
[url "git@github.com:"]
	insteadof = https://github.com/
[safe]
	directory = /opt/greetd-config

{{/* Elective identity overrides (see git_identity_overrides in .chezmoi.toml.tmpl):
     each includes ~/.gitconfig-<identity> when its git includeIf condition matches,
     leaving the default [user] above in place everywhere else. */ -}}
{{ range .git_identity_overrides -}}
[includeIf "{{ .condition }}"]
	path = ~/.gitconfig-{{ .identity }}
{{ end -}}
