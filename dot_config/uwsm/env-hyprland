# Hyprland-specific environment variables
# Reserved for HYPR* and AQ_* variables when needed

# Force libseat to use the logind backend instead of seatd. This user is in the
# `seat` group (needed elsewhere), so /run/seatd.sock is reachable and libseat
# would otherwise pick the seatd backend first. With seatd, the compositor takes
# the seat without informing systemd-logind, leaving the logind session
# Active=no -> no uaccess ACLs on /dev/snd, webcam, etc. (audio devices vanish).
# The logind backend makes logind the seat controller, so the session activates
# and device ACLs are granted on every login. The greeter keeps using seatd.
export LIBSEAT_BACKEND=logind

# Dynamic GPU selection (multi-GPU machines only). hyprstate prints a
# colon-separated DRM device list (primary first) or nothing when unmanaged
# (single GPU, override "off", or any error). Charset + shape guards: anything
# unexpected leaves AQ_DRM_DEVICES unset = compositor defaults = pre-feature
# behavior, so a broken selector can never block login. See GPU_SPEC.md in the
# hyprstate repo. Override: echo igpu|dgpu|off > ~/.config/hypr/gpu-select
_gpu_sel=/usr/local/bin/hyprstate
if [ -x "$_gpu_sel" ]; then
    _aq=$("$_gpu_sel" gpu select 2>/dev/null) || _aq=""
    case "$_aq" in *[!/:.A-Za-z0-9_-]*) _aq="" ;; esac
    # Value is colon-separated /dev/dri/cardN nodes (NOT by-path: aquamarine
    # splits AQ_DRM_DEVICES on ':' and PCI by-path names contain colons).
    case "$_aq" in
        /dev/dri/card*) export AQ_DRM_DEVICES="$_aq" ;;
    esac
fi
unset _gpu_sel _aq