[
  // Disable default space binding for which-key
  {
    "context": "VimControl && !menu",
    "bindings": {
      "space": null
    }
  },

  // ==========================================
  // SPACE LEADER BINDINGS (Vim normal/visual mode)
  // ==========================================
  // Panel toggles use each panel's own ::Toggle action. Unlike
  // ::ToggleFocus (which can only open/focus/unfocus, never hide) and
  // unlike workspace::ToggleLeft/RightDock (tied to a physical dock side,
  // which breaks if a panel is moved), ::Toggle show/hides the specific
  // panel regardless of which dock it lives in.
  // Leader bindings in Editor (also fires inside the agent message box
  // IF that box is a vim-enabled editor — esc to normal mode first).
  {
    "context": "Editor && (vim_mode == normal || vim_mode == visual) && !VimWaiting && !menu",
    "bindings": {
      // File explorer (project panel)
      "space e": "project_panel::Toggle",

      // Claude AI (agent panel)
      "space a c": "agent::Toggle",

      // Git (git panel)
      "space g g": "git_panel::Toggle",

      // File finding
      "space f f": "file_finder::Toggle",
      "space f t": "buffer_search::Deploy",
      "space f r": "tab_switcher::Toggle",

      // Buffer/editor management
      "space b b": "tab_switcher::Toggle",
      "space b d": "pane::CloseActiveItem",
      "space b s": "workspace::Save",
      "space b n": "pane::ActivateNextItem",
      "space b p": "pane::ActivatePreviousItem",

      // Split
      "space v": "pane::SplitRight",

      // General
      // "space h": cleared - use :noh in vim mode instead
      "space w": "editor::ToggleSoftWrap",
      "space q": "workspace::CloseWindow",

      // Tab navigation
      "space tab c": "pane::CloseActiveItem",
      "space tab o": "pane::CloseInactiveItems",
      "space tab h": "pane::ActivatePreviousItem",
      "space tab l": "pane::ActivateNextItem",

      // LSP
      "space l a": "editor::ToggleCodeActions",
      "space l r": "editor::Rename",
      "space l f": "editor::Format"
    }
  },

  // Leader bindings in Project Panel / Explorer (not while renaming a file)
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "space e": "project_panel::Toggle",
      "space a c": "agent::Toggle",
      "space g g": "git_panel::Toggle",
      "space f f": "file_finder::Toggle"
    }
  },

  // Leader bindings when no buffer open (excludes Terminal)
  {
    "context": "Workspace && !Terminal && !Editor",
    "bindings": {
      "space e": "project_panel::Toggle",
      "space a c": "agent::Toggle",
      "space g g": "git_panel::Toggle",
      "space f f": "file_finder::Toggle"
    }
  },

  // Leader bindings in Terminal
  {
    "context": "Terminal",
    "bindings": {
      "space e": "project_panel::Toggle",
      "space a c": "agent::Toggle",
      "space g g": "git_panel::Toggle",
      "space f f": "file_finder::Toggle",

      // Split terminal
      "space v": "pane::SplitRight",
      "space s": "pane::SplitDown"
    }
  },

  // ==========================================
  // ALT+H/J/K/L NAVIGATION (All modes)
  // ==========================================
  {
    "context": "Workspace",
    "bindings": {
      "alt-h": "workspace::ActivatePaneLeft",
      "alt-j": "workspace::ActivatePaneDown",
      "alt-k": "workspace::ActivatePaneUp",
      "alt-l": "workspace::ActivatePaneRight"
    }
  },

  // ==========================================
  // AGENT (CLAUDE) PANEL — close from inside while typing
  // ==========================================
  // A space leader can't fire here: the message box is in `editing` mode,
  // so `space` types a space. This modifier combo works regardless of
  // mode. (If the message box is vim-enabled, `esc` then `space a c` also
  // works via the Editor binding above — this is the always-works path.)
  {
    "context": "AgentPanel",
    "bindings": {
      "ctrl-alt-c": "agent::Toggle"
    }
  }
]
