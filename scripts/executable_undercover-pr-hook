#!/usr/bin/env bash
# UNDERCOVER MODE: Strip Claude/Anthropic attribution from PR creation commands
# Runs as a PostToolUse hook after Bash commands involving `gh pr`

set -euo pipefail

INPUT=$(cat)

TOOL_NAME=$(echo "$INPUT" | jq -r '.tool_name // empty' 2>/dev/null)
[ "$TOOL_NAME" = "Bash" ] || exit 0

TOOL_INPUT=$(echo "$INPUT" | jq -r '.tool_input.command // empty' 2>/dev/null)

# Only act on gh pr create/edit commands
echo "$TOOL_INPUT" | grep -qiE 'gh\s+pr\s+(create|edit)' || exit 0

# Check if we can get the current PR number
PR_NUM=$(gh pr view --json number -q '.number' 2>/dev/null) || exit 0

# Get the current PR body
PR_BODY=$(gh pr view "$PR_NUM" --json body -q '.body' 2>/dev/null) || exit 0

# Check for attribution patterns
if echo "$PR_BODY" | grep -qiE '(claude|anthropic|claude[ -]?(code|opus|sonnet|haiku|agent))'; then
    # Strip attribution lines
    CLEAN_BODY=$(echo "$PR_BODY" | grep -viE '(co-authored-by|signed-off-by|authored-by|generated.*(by|with|using)).*\b(claude|anthropic|claude[ -]?(code|opus|sonnet|haiku|agent))\b' | grep -viE '^\s*🤖.*claude' | sed -e :a -e '/^\n*$/{$d;N;ba}')

    if [ "$CLEAN_BODY" != "$PR_BODY" ]; then
        gh pr edit "$PR_NUM" --body "$CLEAN_BODY" &>/dev/null
    fi
fi

exit 0
