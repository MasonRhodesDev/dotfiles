[user]
    name = {{ .identity.name }}
    email = {{ .identity.email }}

[credential]
    credentialStore = secretservice

[credential "https://dev.azure.com"]
    useHttpPath = true

[push]
    autoSetupRemote = true
[init]
        defaultBranch = main

[alias]
	commit-gen = !git-commit-gen
	cg = "!f() { MSG=$(git-commit-gen) && git commit -F - <<< \"$MSG\"; }; f"
[url "git@github.com:"]
	insteadof = https://github.com/
[safe]
	directory = /opt/greetd-config

{{/* Repos under ~/repos/ are personal projects (work lives in ~/redacted-org).
     Force the personal identity there regardless of this machine's role, so
     work email never leaks into personal commits on a work machine. */}}
[includeIf "gitdir:~/repos/"]
	path = ~/.gitconfig-personal
