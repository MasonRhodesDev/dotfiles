{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "right",
      "segments": [
        {
          "background": "#29315A",
          "foreground": "#E64747",
          "leading_diamond": "蟬ｶ",
          "style": "diamond",
          "template": "{{ if .SSHSession }}㬚｢ｹ {{ end }}{{ .UserName }}",
          "trailing_diamond": "蟬ｴ ",
          "type": "session"
        },
        {
          "background": "#29315A",
          "foreground": "#3EC669",
          "leading_diamond": "蟬ｶ",
          "properties": {
            "style": "folder"
          },
          "style": "diamond",
          "template": "襀ｿ {{ .Path }}",
          "trailing_diamond": "蟬ｴ",
          "type": "path"
        },
        {
          "background": "#29315A",
          "foreground": "#43CCEA",
          "leading_diamond": " 蟬ｶ",
          "properties": {
            "branch_icon": ""
          },
          "style": "diamond",
          "template": "{{ .HEAD }}",
          "trailing_diamond": "蟬ｴ",
          "type": "git"
        },
        {
          "background": "#29315A",
          "foreground": "#E4F34A",
          "leading_diamond": " 蟬ｶ",
          "properties": {
            "fetch_version": false
          },
          "style": "diamond",
          "template": "袘ｵ{{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }}",
          "trailing_diamond": "蟬ｴ",
          "type": "python"
        },
        {
          "background": "#29315A",
          "foreground": "#7FD5EA",
          "leading_diamond": " 蟬ｶ",
          "properties": {
            "fetch_version": false
          },
          "style": "diamond",
          "template": "覔ｦ{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "trailing_diamond": "蟬ｴ",
          "type": "go"
        },
        {
          "background": "#29315A",
          "foreground": "#42E66C",
          "leading_diamond": " 蟬ｶ",
          "properties": {
            "fetch_version": false
          },
          "style": "diamond",
          "template": "觶尞{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }}",
          "trailing_diamond": "蟬ｴ",
          "type": "node"
        },
        {
          "background": "#29315A",
          "foreground": "#E64747",
          "leading_diamond": " 蟬ｶ",
          "properties": {
            "fetch_version": false
          },
          "style": "diamond",
          "template": "訕捜{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "trailing_diamond": "蟬ｴ",
          "type": "ruby"
        },
        {
          "background": "#29315A",
          "foreground": "#E64747",
          "leading_diamond": " 蟬ｶ",
          "properties": {
            "fetch_version": false
          },
          "style": "diamond",
          "template": "觶ｸ{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "trailing_diamond": "蟬ｴ",
          "type": "java"
        },
        {
          "background": "#29315A",
          "foreground": "#9B6BDF",
          "leading_diamond": " 蟬ｶ",
          "properties": {
            "fetch_version": false
          },
          "style": "diamond",
          "template": "覔､{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "蟬ｴ",
          "type": "julia"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "background": "#29315A",
          "foreground": "#AEA4BF",
          "leading_diamond": "蟬ｶ",
          "properties": {
            "style": "austin",
            "threshold": 150
          },
          "style": "diamond",
          "template": "{{ .FormattedMs }}",
          "trailing_diamond": "蟬ｴ ",
          "type": "executiontime"
        },
        {
          "background": "#29315A",
          "foreground": "#7FD5EA",
          "leading_diamond": "蟬ｶ",
          "style": "diamond",
          "template": "笶ｯ",
          "trailing_diamond": "蟬ｴ",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "transient_prompt": {
    "background": "transparent",
    "foreground": "#7FD5EA",
    "template": "笶ｯ "
  },
  "version": 3
}
