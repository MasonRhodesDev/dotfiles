bind=$Meh, l, movefocus, r
bind=$mainMod SHIFT, left, movewindow, l
bind=$mainMod SHIFT, right, movewindow, r
bind=$mainMod SHIFT, up, movewindow, u
bind=$mainMod SHIFT, down, movewindow, d
# ===== Workspace bindings with double-tap special workspace support =====
# Single tap: switch to workspace N
# Double tap (while holding SUPER): toggle special:N

# Workspace 1
bind = $mainMod, 1, workspace, 1
bind = $mainMod, 1, submap, ws1
submap = ws1, reset
bind = $mainMod, 1, togglespecialworkspace, 1
bind = , catchall, submap, reset
submap = reset

# Workspace 2
bind = $mainMod, 2, workspace, 2
bind = $mainMod, 2, submap, ws2
submap = ws2, reset
bind = $mainMod, 2, togglespecialworkspace, 2
