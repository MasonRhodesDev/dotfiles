#!/bin/bash
# Freeze screen → select region → capture → annotate → clipboard
# hyprpicker -r -z creates a freeze overlay that doesn't block slurp pointer input

FREEZE_PID=
TMPFILE=

stop_freeze_pid() {
    local pid="$1"

    [[ -z "$pid" ]] && return

    kill "$pid" 2>/dev/null || true
    sleep 0.1

    if kill -0 "$pid" 2>/dev/null; then
        kill -9 "$pid" 2>/dev/null || true
    fi
}

clear_stale_freeze() {
    local pid

    while read -r pid; do
        stop_freeze_pid "$pid"
    done < <(pgrep -x -f 'hyprpicker -r -z' 2>/dev/null || true)
}

cleanup() {
    if [[ -n "$FREEZE_PID" ]]; then
        stop_freeze_pid "$FREEZE_PID"
        wait "$FREEZE_PID" 2>/dev/null || true
        FREEZE_PID=
    fi

    if [[ -n "$TMPFILE" ]]; then
        rm -f "$TMPFILE"
    fi
}

trap cleanup EXIT INT TERM HUP

clear_stale_freeze

hyprpicker -r -z &
FREEZE_PID=$!
sleep 0.2

SELECTION=$(slurp -d 2>/dev/null)
SLURP_STATUS=$?

cleanup

[ $SLURP_STATUS -ne 0 ] && exit 1
[ -z "$SELECTION" ] && exit 1

TMPFILE=$(mktemp /tmp/snip-XXXXXX.ppm)
grim -g "$SELECTION" -t ppm "$TMPFILE" 2>/dev/null
GRIM_STATUS=$?

[ $GRIM_STATUS -ne 0 ] && { rm -f "$TMPFILE"; exit 1; }

OUTPUT_FILE="$HOME/Pictures/Screenshots/$(date +%Y%m%d-%H%M%S).png"

satty --filename "$TMPFILE" \
      --copy-command "wl-copy" \
      --early-exit \
      --output-filename "$OUTPUT_FILE"

rm -f "$TMPFILE"
TMPFILE=
