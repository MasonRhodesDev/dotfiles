# swaync notification daemon.
# Reloads CSS + config on theme switch so the palette stays in sync.
# style.css @imports ~/.config/matugen/lmtt-colors.css, so a reload is all
# that's needed here.

name = "swaync"
description = "Reload swaync on theme switch"
binary = "swaync"
priority = 100

[script]
path = "~/.config/lmtt/scripts/swaync-reload.sh"
timeout = 3000
