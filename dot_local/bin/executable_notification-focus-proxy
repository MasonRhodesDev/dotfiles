#!/usr/bin/env python3
"""notification-focus-proxy

Bridge the gap between the XDG Desktop Notifications spec and Wayland apps
that don't properly consume activation tokens.

Per the spec (https://specifications.freedesktop.org/notification/latest-single/),
when the user clicks a notification, the daemon emits:

    ActivationToken (UINT32 id, STRING token)   — xdg-activation token
    ActionInvoked   (UINT32 id, STRING key)     — key = "default" for body click

The sender app is expected to consume the ActivationToken and call
xdg_activation_v1.activate() to receive focus. Electron apps (Slack,
Discord, …) frequently fail to do this on Wayland. So we do it ourselves:
when we see an ActionInvoked, we look up the notification's sender identity
and `hyprctl dispatch focuswindow` the matching client.

Implementation: parse `dbus-monitor` text output. Simpler and more reliable
than GDBus monitor mode in Python.
"""

from __future__ import annotations

import logging
import os
import re
import subprocess
import sys

FOCUS_SCRIPT = os.path.expanduser("~/.config/swaync/scripts/focus-sender.sh")

log = logging.getLogger("notification-focus-proxy")

# dbus-monitor line formats we care about. We split messages on header lines
# and collect body lines until the next header.
HEADER_RE = re.compile(
    r"^(?P<kind>method call|method return|signal|error)\s+time=\S+"
    r".*?(?:\s+serial=(?P<serial>\d+))"
    r"(?:\s+reply_serial=(?P<reply_serial>\d+))?"
    r"(?:.*?\s+interface=(?P<interface>\S+?);)?"
    r"(?:.*?\s+member=(?P<member>\S+))?"
)
STRING_RE = re.compile(r'^\s+string\s+"(.*)"\s*$')
VARIANT_STRING_RE = re.compile(r'^\s+variant\s+string\s+"(.*)"\s*$')
UINT32_RE = re.compile(r"^\s+uint32\s+(\d+)\s*$")


def _parse_notify_body(lines: list[str]) -> dict:
    """Extract app_name + desktop-entry hint from a Notify call body."""
    result = {"app_name": "", "desktop_entry": ""}
    # First top-level string is app_name.
    for line in lines:
        m = STRING_RE.match(line)
        if m:
            result["app_name"] = m.group(1)
            break
    # Find `string "desktop-entry"` followed by `variant string "..."`.
    for i, line in enumerate(lines):
        m = STRING_RE.match(line)
        if m and m.group(1) == "desktop-entry":
            for j in range(i + 1, min(i + 4, len(lines))):
                v = VARIANT_STRING_RE.match(lines[j])
                if v:
                    result["desktop_entry"] = v.group(1)
                    return result
    return result


def _first_uint32(lines: list[str]) -> int | None:
    for line in lines:
        m = UINT32_RE.match(line)
        if m:
            return int(m.group(1))
    return None


def _fire_focus(identity: dict) -> None:
    env = os.environ.copy()
    env["SWAYNC_APP_NAME"] = identity.get("app_name", "") or ""
    env["SWAYNC_DESKTOP_ENTRY"] = identity.get("desktop_entry", "") or ""
    if not (env["SWAYNC_APP_NAME"] or env["SWAYNC_DESKTOP_ENTRY"]):
        log.debug("empty identity, skipping focus")
        return
    log.info(
        "focus: app_name=%r desktop_entry=%r",
        env["SWAYNC_APP_NAME"],
        env["SWAYNC_DESKTOP_ENTRY"],
    )
    try:
        subprocess.Popen(
            [FOCUS_SCRIPT],
            env=env,
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            close_fds=True,
        )
    except FileNotFoundError:
        log.error("focus script not found: %s", FOCUS_SCRIPT)
    except Exception as e:
        log.error("failed to spawn focus script: %s", e)


def main() -> int:
    logging.basicConfig(
        level=os.environ.get("LOG_LEVEL", "INFO").upper(),
        format="%(asctime)s %(levelname)s %(message)s",
    )

    pending: dict[int, dict] = {}   # serial → identity (Notify call in flight)
    active: dict[int, dict] = {}    # notification id → identity

    cmd = ["dbus-monitor", "--session"]
    log.info("spawning: %s", " ".join(cmd))
    proc = subprocess.Popen(
        cmd,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        stdin=subprocess.DEVNULL,
        text=True,
        bufsize=1,
    )
    assert proc.stdout is not None

    current: dict | None = None
    body_lines: list[str] = []

    def flush() -> None:
        nonlocal current, body_lines
        if current is None:
            return
        kind = current["kind"]
        member = current.get("member") or ""
        interface = current.get("interface") or ""
        serial = current.get("serial")
        reply_serial = current.get("reply_serial")

        try:
            if kind == "method call" and interface == "org.freedesktop.Notifications" and member == "Notify":
                identity = _parse_notify_body(body_lines)
                if serial is not None:
                    pending[serial] = identity
                    log.debug("Notify serial=%s identity=%s", serial, identity)

            elif kind == "method return" and reply_serial in pending:
                identity = pending.pop(reply_serial)
                notif_id = _first_uint32(body_lines)
                if notif_id is not None:
                    active[notif_id] = identity
                    log.debug("tracked id=%s %s", notif_id, identity)

            elif kind == "signal" and interface == "org.freedesktop.Notifications" and member == "ActionInvoked":
                notif_id = _first_uint32(body_lines)
                log.debug("ActionInvoked id=%s active=%s", notif_id, list(active.keys()))
                if notif_id in active:
                    _fire_focus(active.pop(notif_id))

            elif kind == "signal" and interface == "org.freedesktop.Notifications" and member == "NotificationClosed":
                # Many apps (Slack, Discord, …) don't attach a "default" action
                # to their notifications, so clicking the body emits only
                # NotificationClosed(reason=2) — no ActionInvoked. Treat that
                # like a click if we haven't already fired focus for this id.
                # reason codes: 1=expired, 2=dismissed by user, 3=CloseNotification,
                # 4=undefined.
                ids = [int(m.group(1)) for line in body_lines
                       for m in [UINT32_RE.match(line)] if m]
                notif_id = ids[0] if ids else None
                reason = ids[1] if len(ids) > 1 else None
                log.debug("NotificationClosed id=%s reason=%s tracked=%s",
                          notif_id, reason, notif_id in active)
                if notif_id in active:
                    if reason == 2:
                        _fire_focus(active.pop(notif_id))
                    else:
                        active.pop(notif_id, None)

        except Exception:
            log.exception("error handling message")

        current = None
        body_lines = []

    log.info("ready; watching org.freedesktop.Notifications")
    try:
        for raw in proc.stdout:
            line = raw.rstrip("\n")
            if not line:
                continue
            header = HEADER_RE.match(line)
            if header and header.group("kind"):
                flush()
                current = {
                    "kind": header.group("kind"),
                    "serial": (
                        int(header.group("serial"))
                        if header.group("serial") else None
                    ),
                    "reply_serial": (
                        int(header.group("reply_serial"))
                        if header.group("reply_serial") else None
                    ),
                    "interface": header.group("interface"),
                    "member": header.group("member"),
                }
            elif current is not None:
                body_lines.append(line)
    except KeyboardInterrupt:
        pass
    finally:
        flush()
        proc.terminate()
        try:
            proc.wait(timeout=2)
        except subprocess.TimeoutExpired:
            proc.kill()

    rc = proc.returncode or 0
    log.warning("dbus-monitor exited with %s", rc)
    return 1 if rc != 0 else 0


if __name__ == "__main__":
    sys.exit(main())
