#!/usr/bin/env bash
# Unified workspace management for Hyprland
# Handles workspace switching, special workspace toggling, and window moving
# with proper coordination to prevent race conditions
set -euo pipefail

RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp}/hypr-workspace"
mkdir -p "$RUNTIME_DIR"

# === Shared Functions ===

get_focused_monitor_json() {
    hyprctl monitors -j | jq '.[] | select(.focused == true)'
}

get_active_special() {
    # Returns special workspace name (e.g., "special:7") or empty
    get_focused_monitor_json | jq -r '.specialWorkspace.name // empty'
}

get_current_workspace() {
    hyprctl activeworkspace -j | jq -r '.id'
}

get_workspace_monitor() {
    local ws="$1"
    # Get monitor ID for a workspace, empty if workspace doesn't exist yet
    hyprctl workspaces -j | jq -r --arg ws "$ws" '.[] | select(.id == ($ws | tonumber)) | .monitorID // empty'
}

# === Listener Management ===

get_listener_pid_file() {
    echo "$RUNTIME_DIR/listener-$1.pid"
}

kill_listener() {
    local ws="$1"
    local pid_file=$(get_listener_pid_file "$ws")
    if [[ -f "$pid_file" ]]; then
        local pid=$(cat "$pid_file")
        kill "$pid" 2>/dev/null || true
        rm -f "$pid_file"
    fi
}

start_listener() {
    local ws="$1"
    local socket="${XDG_RUNTIME_DIR}/hypr/${HYPRLAND_INSTANCE_SIGNATURE}/.socket2.sock"
    local pid_file=$(get_listener_pid_file "$ws")

    (
        echo $$ > "$pid_file"
        socat -U - "UNIX-CONNECT:$socket" | while read -r line; do
            case "$line" in
                workspace\>\>*|workspacev2\>\>*)
                    # Only close if still active (prevents race)
                    local current=$(get_active_special)
                    if [[ "$current" == "special:$ws" ]]; then
                        hyprctl dispatch togglespecialworkspace "$ws" 2>/dev/null
                    fi
                    break
                    ;;
                activespecial\>\>*)
                    local current=$(get_active_special)
                    if [[ "$current" != "special:$ws" ]]; then
                        break
                    fi
                    ;;
            esac
        done
        rm -f "$pid_file"
    ) &
    disown
}

# === Commands ===

cmd_switch() {
    local target="$1"
    local target_monitor=$(get_workspace_monitor "$target")
    local focused_monitor=$(get_focused_monitor_json | jq -r '.id')

    # If workspace doesn't exist, it will be created on focused monitor
    if [[ -z "$target_monitor" ]]; then
        target_monitor="$focused_monitor"
    fi

    # Only close special workspace if target is on the currently focused monitor
    # (togglespecialworkspace only works on focused monitor)
    if [[ "$target_monitor" == "$focused_monitor" ]]; then
        local special=$(get_active_special)
        if [[ -n "$special" && "$special" != "null" ]]; then
            local name="${special#special:}"
            kill_listener "$name"
            hyprctl dispatch togglespecialworkspace "$name"
        fi
    fi

    hyprctl dispatch workspace "$target"
}

cmd_toggle_special() {
    local ws=$(get_current_workspace)

    # Don't operate from special workspaces
    if [[ "$ws" -lt 0 ]]; then
        local special=$(get_active_special)
        local name="${special#special:}"
        hyprctl dispatch togglespecialworkspace "$name"
        return
    fi

    local current=$(get_active_special)
    if [[ "$current" == "special:$ws" ]]; then
        # Close it
        kill_listener "$ws"
        hyprctl dispatch togglespecialworkspace "$ws"
    else
        # Open it with auto-dismiss listener
        hyprctl dispatch togglespecialworkspace "$ws"
        start_listener "$ws"
    fi
}

cmd_move_to_special() {
    local ws=$(get_current_workspace)

    # Don't operate from special workspaces
    if [[ "$ws" -lt 0 ]]; then
        return
    fi

    hyprctl dispatch movetoworkspace "special:$ws"
}

# === Main ===

case "${1:-}" in
    switch)
        cmd_switch "${2:?Usage: hypr-workspace switch <N>}"
        ;;
    toggle-special)
        cmd_toggle_special
        ;;
    move-to-special)
        cmd_move_to_special
        ;;
    *)
        echo "Usage: hypr-workspace {switch|toggle-special|move-to-special} [args]"
        exit 1
        ;;
esac
