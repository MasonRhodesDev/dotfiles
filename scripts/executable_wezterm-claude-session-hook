#!/usr/bin/env bash
# SessionStart hook for WezTerm pane correlation
# Captures WEZTERM_PANE when Claude Code session starts
# Receives JSON on stdin with session_id, transcript_path, cwd, etc.

# Read hook input JSON from stdin
INPUT=$(cat)

# Extract session_id and transcript_path from JSON
if command -v jq >/dev/null 2>&1; then
    SESSION_ID=$(echo "$INPUT" | jq -r '.session_id')
    TRANSCRIPT_PATH=$(echo "$INPUT" | jq -r '.transcript_path')
else
    # Fallback regex extraction without jq
    SESSION_ID=$(echo "$INPUT" | grep -o '"session_id":"[^"]*"' | cut -d'"' -f4)
    TRANSCRIPT_PATH=$(echo "$INPUT" | grep -o '"transcript_path":"[^"]*"' | cut -d'"' -f4)
fi

# Only proceed if in WezTerm or kitty (both interpret OSC 1337 SetUserVar)
if [[ -z "$WEZTERM_PANE" && -z "$KITTY_WINDOW_ID" ]]; then
    echo "{}"
    exit 0
fi

# Get the TTY device for this specific pane. TERM decides the terminal:
# a stale WEZTERM_PANE survives nested terminal launches (kitty opened from
# a wezterm shell), and asking wezterm for that pane's tty would send our
# escape codes to the wrong window.
TTY_DEVICE=""
if [[ "$TERM" != *kitty* && -n "$WEZTERM_PANE" ]]; then
    TTY_DEVICE=$(wezterm cli list --format json 2>/dev/null | \
        jq -r ".[] | select(.pane_id == $WEZTERM_PANE) | .tty_name" | head -1)
fi

if [[ -z "$TTY_DEVICE" ]]; then
    # kitty (or wezterm cli failure): hooks run with piped stdio, so walk up
    # the process tree to the agent process's controlling TTY
    pid=$$
    for _ in 1 2 3 4 5; do
        pid=$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ')
        [[ -z "$pid" || "$pid" -le 1 ]] && break
        t=$(ps -o tty= -p "$pid" 2>/dev/null | tr -d ' ')
        if [[ -n "$t" && "$t" != "?" ]]; then
            TTY_DEVICE="/dev/$t"
            break
        fi
    done
fi

if [[ -z "$TTY_DEVICE" ]]; then
    # Fallback: use current TTY
    TTY_DEVICE=$(tty 2>/dev/null || echo "/dev/tty")
fi

# Create pane correlation directory
CORRELATION_DIR="/tmp/claude-wezterm"
mkdir -p "$CORRELATION_DIR"

# Write pane correlation file: session_id → pane_id + TTY
CORRELATION_FILE="$CORRELATION_DIR/$SESSION_ID.pane"
cat > "$CORRELATION_FILE" <<EOF
WEZTERM_PANE=$WEZTERM_PANE
SESSION_FILE=$TRANSCRIPT_PATH
TTY_DEVICE=$TTY_DEVICE
TIMESTAMP=$(date +%s)
EOF

# Send a SetUserVar OSC to the pane TTY. Inside tmux the discovered TTY is
# the pane pty (tmux's, not the terminal's): wrap in the tmux DCS passthrough
# envelope (ESCs doubled) so tmux forwards the OSC to the attached client.
# Needs `allow-passthrough on` (set in ~/.tmux.conf).
send_user_var() {
    local seq
    seq=$(printf '\033]1337;SetUserVar=%s=%s\007' "$1" "$(printf '%s' "$2" | base64 -w0)")
    if [[ -n "$TMUX" ]]; then
        seq=$(printf '\033Ptmux;%s\033\\' "${seq//$'\033'/$'\033'$'\033'}")
    fi
    printf '%s' "$seq" > "$TTY_DEVICE" 2>/dev/null
}

# Set initial CLAUDE_ACTIVE user variable for this pane
send_user_var CLAUDE_ACTIVE 1

# Set CLAUDE_MODEL user variable from settings
CLAUDE_SETTINGS="$HOME/.claude/settings.json"
if [[ -f "$CLAUDE_SETTINGS" ]] && command -v jq >/dev/null 2>&1; then
    CLAUDE_MODEL=$(jq -r '.model // empty' "$CLAUDE_SETTINGS" 2>/dev/null)
    if [[ -n "$CLAUDE_MODEL" ]]; then
        send_user_var CLAUDE_MODEL "$CLAUDE_MODEL"
    fi
fi

# Return success JSON to Claude Code
# Note: Activity updates now handled by wezterm-claude-activity-hook
echo '{"status": "success"}'
