# Theme managed by theme-toggle-modular.sh - no static theme setting needed

# Initialize theme state and apply current theme
exec-once = dbus-update-activation-environment --all
exec-once=sleep 1 & dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP
# gnome-keyring: PAM handles all components now (socket activation masked)
# exec-once = gnome-keyring-daemon --start --components=ssh
exec-once = /home/mason/.config/hypr/configs/monitors.sh > /home/mason/.config/hypr/logs/monitors.log 2>&1

# Initialize theme on login
exec-once = lmtt switch dark

