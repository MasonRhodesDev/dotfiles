{
  "backlight": {
    "format": "{percent}% {icon}",
    "format-icons": [
      "ΌΟΞ",
      "ΌΠΥ",
      "ΌΠΣ",
      "ΌΠΠ",
      "ΌΠΟ",
      "ΌΠΞ",
      "ΌΠΛ",
      "ΌΠΙ",
      "ΌΟδ"
    ]
  },
  "battery": {
    "bat": "hidpp_battery_0",
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% ",
    "format-icons": [ "≤░ΓΕ", "≤░ΓΕ", "≤░ΓΕ", "≤░ΓΕ", "≤░ΓΕ"],
    "format-plugged": "{capacity}% ",
    "states": {
      "critical": 20,
      "good": 95,
      "warning": 30
    },

    "on-click": ""
  },
  "clock": {
    "format": "       {:%R\n %d.%m.%Y}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#ffdea3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff8699'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  "cpu": {
    "format": "{usage}% ΎΜδ",
    "tooltip": false
  },
  "custom/headsetcontrol_battery": {
      "exec": "/home/mason/scripts/headsetcontrol-json",
      "interval": 2,
      "return-type": "json"
    },
  "custom/media": {
    "escape": true,
    "exec": "{{ .chezmoi.homeDir }}/scripts/whatsong",
    "format": "{icon} {}",
    "interval": 10,
    "format-icons": {
      "default": "ΏθΟε",
      "spotify": "ΎΗ╝"
    },
    "max-length": 40,
    "return-type": "json"
  },
  "custom/pritunl": {
    "exec": "pritunl-status",
    "format": "{icon} {status}",
    "interval": 5,
    "return-type": "json"
  },
  "custom/recorder": {
    "exec": "echo '{\"class\": \"recording\"}'",
    "exec-if": "pgrep wf-recorder",
    "format": "ΎΑ╜",
    "interval": 1,
    "on-click": "record",
    "return-type": "json"
  },
  "height": 30,
  "hyprland/window": {
    "max-length": 200,
    "separate-outputs": true
  },
  "hyprland/workspaces": {
    "format": "{icon}",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "on-scroll-up": "hyprctl dispatch workspace e+1"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "ΎΒχ",
      "deactivated": "ΎΒ░"
    }
  },
  "keyboard-state": {
    "capslock": true,
    "format": "{name} {icon} ",
    "format-icons": {
      "locked": "ΎΑμ",
      "unlocked": "ΎΓε"
    },
    "numlock": true
  },
  "layer": "top",
  "memory": {
    "format": "{}% ΎΔΚ"
  },
  "modules-center": [
    "clock",
    "custom/recorder"
  ],
  "modules-left": [
    "hyprland/workspaces",
    "hyprland/window"
  ],
  "modules-right": [
    "custom/media",
    "idle_inhibitor",
    "wireplumber",
    "network",
    "cpu",
    "memory",
    "temperature",
    "backlight",
    "keyboard-state",
    "battery",
    "custom/headsetcontrol_battery",
    "tray",
    "dunst"
  ],
  "network": {
    "format-alt": "{ifname}: {ipaddr}/{cidr}",
    "format-disconnected": "Disconnected έγι",
    "format-ethernet": "{ipaddr}/{cidr} ≤░ΙΑ",
    "format-linked": "{ifname} (No IP) ≤░ΙΑ",
    "format-wifi": "{essid} ({signalStrength}%) ΎΘτ",
    "on-middle-click": "nm-connection-editor",
    "tooltip-format": "{ifname} via {gwaddr}"
  },
  "spacing": 4,
  "temperature": {
    "hwmon-path": "/sys/class/hwmon/hwmon0/temp1_input",
    "critical-threshold": 80,
    "format": "{temperatureC}┬░C {icon}",
    "format-icons": [
      "≤░ΦΠ",
      "≤░ΦΡ", 
      "≤▒ΩΩ"
    ],
    "tooltip": false
  },
  "tray": {
    "spacing": 10
  },
  "wireplumber": {
    "format": "{volume}% {icon}",
    "format-icons": [
      "ΎΑο",
      "ΎΑπ",
      "ΎΑρ"
    ],
    "format-muted": "ΎΑο",
    "on-click": "{{ .chezmoi.homeDir }}/.config/wofi/change-default-audio-device.js WofiListAudioDevices",
    "on-click-right": "pavucontrol"
  },
  "dunst": {
    "format": "{icon}",
    "format-icons": {
      "default": "≤░Γγ",
      "paused": "≤░Γδ"
    },
    "on-click": "dunstctl history-pop",
    "on-click-right": "dunstctl set-paused toggle",
    "tooltip": true,
    "tooltip-format": "{count} notifications"
  }
}