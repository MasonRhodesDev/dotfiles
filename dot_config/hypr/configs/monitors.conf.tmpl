# Monitor and workspace rules are managed by hyprstate via per-setup profile
# files in ~/.config/hypr/profiles/. The daemon repoints `.active.conf` based
# on which monitors are connected and runs `hyprctl reload`.
#
# To add/edit a profile, drop a .conf in ~/.config/hypr/profiles/ with `#@`
# directive comments — see existing profiles for the format.
#
# Evaluation is by first match, so the active profile sources first; the
# fallbacks below only apply if a profile rule didn't already cover them.

source = ~/.config/hypr/profiles/.active.conf

# Fallbacks — picked up only when no profile rule matches.
monitor = eDP-2,2560x1600@165,auto,1.25
monitor = ,preferred,auto,1
