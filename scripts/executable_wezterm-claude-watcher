#!/usr/bin/env bash
# Event-driven Claude activity watcher for WezTerm
# Watches a manually registered session file for activity updates

# Only run in Claude sessions
[[ "${CLAUDECODE:-0}" != "1" ]] && exit 0

TTY_DEVICE="${1:-/dev/tty}"  # Terminal device to write OSC sequences to
CLAUDE_PPID="${2:-$$}"       # Parent PID to identify this session
STATUS_FILE="/tmp/claude-activity-$$"
MARKER_FILE="/tmp/claude-session-$CLAUDE_PPID"

# Cleanup on exit
trap "rm -f '$STATUS_FILE'" EXIT

# Function to extract activity from session file
# Extracts the session slug as the overall task description
extract_activity() {
    local session_file="$1"

    # Get the session slug (human-readable task description)
    local slug=$(grep -m 1 '"slug":' "$session_file" 2>/dev/null | \
        jq -r '.slug' 2>/dev/null | \
        sed 's/-/ /g' | \
        head -c 40)

    if [[ -n "$slug" ]]; then
        echo "$slug"
        return
    fi

    # No slug found - return empty (will show just "Claude")
    echo ""
}

# Read session file from marker file (must be manually registered)
if [[ ! -f "$MARKER_FILE" ]]; then
    # No marker file - exit gracefully (status will show just "Claude")
    exit 0
fi

SESSION_FILE=$(cat "$MARKER_FILE" 2>/dev/null)

# Verify the session file exists
if [[ -z "$SESSION_FILE" ]] || [[ ! -f "$SESSION_FILE" ]]; then
    exit 0
fi
if [[ -n "$SESSION_FILE" ]] && [[ -f "$SESSION_FILE" ]]; then
    ACTIVITY=$(extract_activity "$SESSION_FILE")

    # If no activity found (new/empty session), use empty string
    # This will make WezTerm show just "Claude" without activity text
    if [[ -z "$ACTIVITY" ]]; then
        ACTIVITY=""
    fi

    echo "$ACTIVITY" > "$STATUS_FILE"

    # Send initial OSC sequence to WezTerm (write to terminal device)
    # Send even if empty to clear any previous activity
    printf '\033]1337;SetUserVar=CLAUDE_ACTIVITY=%s\007' "$(echo -n "$ACTIVITY" | base64)" > "$TTY_DEVICE" 2>/dev/null
fi

# Watch for changes to the session file
if [[ -n "$SESSION_FILE" ]] && command -v inotifywait >/dev/null 2>&1; then
    inotifywait -m -e modify "$SESSION_FILE" 2>/dev/null | while read -r; do
        ACTIVITY=$(extract_activity "$SESSION_FILE")

        # Always update, even if empty (to clear stale activity)
        echo "$ACTIVITY" > "$STATUS_FILE"

        # Send OSC sequence to WezTerm to update status (write to terminal device)
        printf '\033]1337;SetUserVar=CLAUDE_ACTIVITY=%s\007' "$(echo -n "$ACTIVITY" | base64)" > "$TTY_DEVICE" 2>/dev/null
    done
fi
