{{ if not .is_work -}}
[Unit]
Description=Big Picture / game focus state machine (Hyprland)
PartOf=graphical-session.target
After=graphical-session.target
# uwsm finalizes HYPRLAND_INSTANCE_SIGNATURE into the user manager before
# graphical-session.target activates; skip cleanly if it's absent.
ConditionEnvironment=HYPRLAND_INSTANCE_SIGNATURE

[Service]
Type=simple
ExecStart=%h/.config/hypr/scripts/bp-game-focus.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
{{ end -}}
