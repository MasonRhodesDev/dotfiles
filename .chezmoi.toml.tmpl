# .chezmoi.toml
{{/* Read the static hostname directly: .chezmoi.hostname can be poisoned by
     stray /etc/hosts entries (e.g. a leftover "127.0.0.1 openclaw.local" once
     made it return "openclaw" and silently flipped is_work to false). */}}
{{- $hostname := .chezmoi.hostname -}}
{{- $staticHostname := output "sh" "-c" "cat /etc/hostname 2>/dev/null || true" | trim -}}
{{- if $staticHostname }}{{ $hostname = $staticHostname }}{{ end -}}

{{/* Machine role is DECLARED, not inferred: asked once on the first
     `chezmoi init` on a new machine, then persisted in the rendered config
     and reused on every re-init. Hostname only seeds the first-run default.
     Non-interactive bootstrap:
       chezmoi init --promptBool "Is this a work machine"=true */}}
{{- $is_work := promptBoolOnce . "is_work" "Is this a work machine" (eq $hostname "mason-work") -}}
[edit]
    command="nvim"
[merge]
    command="nvim"
    args = ["-d"]
[git]
    autoCommit = true
    autoPush = true
[data]
    wallpaper = {{ if $is_work }}"/home/mason/Pictures/forrest.png"{{ else }}"/home/mason/Pictures/landscape.png"{{ end }}
    is_work = {{ $is_work }}

# Profile configuration
[data.profile]
    type = {{ if $is_work }}"work"{{ else }}"personal"{{ end }}

# System tracking - updated on each chezmoi apply
[data.system]
    hostname = "{{ $hostname }}"
    os = "{{ .chezmoi.os }}"
    os_release_id = "{{ .chezmoi.osRelease.id }}"
    os_release_version = "{{ if hasKey .chezmoi.osRelease "versionID" }}{{ .chezmoi.osRelease.versionID }}{{ else }}rolling{{ end }}"
    arch = "{{ .chezmoi.arch }}"
    last_updated = "{{ now | date "2006-01-02T15:04:05Z07:00" }}"
    
# System manifest tracking file location
[data.tracking]
    manifest_file = ".system_manifest.json"

{{/* Machine-varying identity + private data: fetched ONCE per machine from the
     Bitwarden `chezmoi-data` note in a SINGLE rbwFields call, then persisted in
     this rendered config — real values never live in the public repo. Precedence
     per value:
       1. CHEZMOI_IDENTITY_* env var (refresh path: chezmoi-refresh-identity
          exports fresh values from Bitwarden and re-runs init)
       2. value already stored in this config (reused on re-init)
       3. the Bitwarden note (only queried when rbw is installed, unlocked, and
          identity isn't already stored — so a locked/headless init never blocks;
          it just falls back to stored values or the prompt)
     Normal `chezmoi apply` never touches rbw at all. */}}
{{- $fields := dict -}}
{{- if and (lookPath "rbw") (not (hasKey . "identity")) (not (env "CHEZMOI_IDENTITY_NAME")) -}}
{{-   if eq (output "sh" "-c" "rbw unlocked >/dev/null 2>&1 && echo yes || true" | trim) "yes" -}}
{{-     $fields = rbwFields "chezmoi-data" -}}
{{-   end -}}
{{- end -}}
{{- $seedName := dig "name" "value" "" $fields -}}
{{- $seedWork := dig "email_work" "value" "" $fields -}}
{{- $seedPersonal := dig "email_personal" "value" "" $fields -}}
{{- $seedOverrides := dig "git_overrides" "value" "" $fields -}}
{{- $seedClaudeMd := dig "work_claude_md" "value" "" $fields -}}
{{- $seedOverlay := dig "work_overlay_repo" "value" "" $fields -}}
{{- $name := or (env "CHEZMOI_IDENTITY_NAME") (promptStringOnce . "identity.name" "Full name (git author)" $seedName) -}}
{{- $emailWork := or (env "CHEZMOI_IDENTITY_EMAIL_WORK") (promptStringOnce . "identity.email_work" "Work email" $seedWork) -}}
{{- $emailPersonal := or (env "CHEZMOI_IDENTITY_EMAIL_PERSONAL") (promptStringOnce . "identity.email_personal" "Personal email" $seedPersonal) -}}

{{- /* Structured private data: prefer a fresh Bitwarden seed, else reuse the
       value already stored in this config (so re-init without rbw still works). */ -}}
{{- $overridesJson := or (env "CHEZMOI_GIT_OVERRIDES") $seedOverrides (dig "git" "overrides_json" "" .) -}}
{{- $claudeMd := or (env "CHEZMOI_WORK_CLAUDE_MD") $seedClaudeMd (dig "work" "claude_md" "" .) -}}
{{- $overlayRepo := or (env "CHEZMOI_WORK_OVERLAY_REPO") $seedOverlay (dig "work" "overlay_repo" "" .) -}}
{{- $overrides := list (dict "condition" "gitdir:~/repos/" "identity" "personal") -}}
{{- if $overridesJson -}}{{- $overrides = fromJson $overridesJson -}}{{- end -}}
[data.identity]
    name = {{ $name | quote }}
    email_work = {{ $emailWork | quote }}
    email_personal = {{ $emailPersonal | quote }}
    email = {{ if $is_work }}{{ $emailWork | quote }}{{ else }}{{ $emailPersonal | quote }}{{ end }}

# Private, machine-varying data sourced from the Bitwarden `chezmoi-data` note
# (see the fetch block above), stored here so re-init without rbw reuses it.
# Never put real values in the public source templates — they come from here.
[data.git]
    # JSON array of {condition, identity} git includeIf overrides (org names live
    # in Bitwarden, not the repo). dot_gitconfig.tmpl ranges over the parsed list.
    overrides_json = {{ $overridesJson | quote }}

[data.work]
    claude_md = {{ $claudeMd | quote }}
    overlay_repo = {{ $overlayRepo | quote }}

{{ range $overrides -}}
[[data.git_identity_overrides]]
    condition = {{ .condition | quote }}
    identity = {{ .identity | quote }}
{{ end -}}
