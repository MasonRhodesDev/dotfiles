


#windowrule = match:class ^(.*)$, move onscreen cursor

# Keep all floating windows above tiled windows
windowrule = match:float 1, pin on

windowrule = match:title ^(keep.google.com_/)$, tile on
windowrule = match:class ^(discord)$, workspace special:magic silent
windowrule = match:class ^(Slack)$, workspace special:magic silent
windowrule = match:title ^(YouTube Music)$, workspace special:magic silent
windowrule = match:class ^(kitty)$, size 100 100
# windowrule = match:workspace special:magic, opacity 0.9 0.7
windowrule = match:title ^(Helvum)$, float on
windowrule = match:title ^(_crx_nngceckbapebfimnlniiiahkandclblb)$, float on
windowrule = match:title ^(Picture in picture)$, float on, pin on, opacity 0.9 0.9
windowrule = match:title ^(MainPicker)$, opacity 1 1
windowrule = match:title ^(meet.google.com is sharing.*)$, opacity 1 1, float on, pin on
windowrule = match:title ^(Huddle.*)$, opacity 1 1
windowrule = match:title ^(.*Bitwarden.*)$, float on
windowrule = match:class ^(gcr-prompter)$, float on, pin on, center on, stay_focused on

# Voice dictation window - change 80 in move rule below to adjust bottom offset
windowrule = match:class ^(dev.mason.dictation)$, float on, pin on, size 200 50, move 50%-100 95%, border_size 0, no_blur on, no_shadow on, no_initial_focus on, no_focus on

windowrule = match:title ^(PRE_SLEEP_WINDOW)$, float on, move -2000 -2000, size 10000 10000, opacity 0.95 override 0.95 override 0.95 override, xray off
windowrule = match:title ^(Sign in - Google Accounts.*)$, float on

# Chrome for Testing (Puppeteer) - send to special:mcp-puppeteer
windowrule = match:title ^(.*Chrome for Testing)$, workspace special:mcp-puppeteer silent

# wofi window rules (normal window mode)
windowrule = match:class ^(wofi)$, float on, opacity 0.99999 0.99999, center on, stay_focused on, pin on

# pavucontrol rules
windowrule = match:class ^(hyprpwcenter)$, float on, center on, size 1000 600, stay_focused on, pin on

# Satty screenshot annotation - always on top
windowrule = match:class ^(com.gabm.satty)$, float on, pin on, center on, stay_focused on

# Android Emulator
windowrule = match:class ^(Emulator)$, float on

# Steam rules
# Only send the main Steam window to special workspace (not popups/menus)
windowrule = match:class ^(steam)$, match:title ^(Steam)$, workspace special:magic silent, no_initial_focus on, focus_on_activate off
# Prevent 5x5 spawn bug for empty title steam windows
windowrule = match:title ^()$, match:class ^(steam)$, stay_focused on, min_size 1 1

{{ if not .is_work }}
# Game rules (personal PC only)
# Gamescope and Steam games on workspace 7
workspace = 7, border:false, rounding:false
windowrule = match:class ^(gamescope)$, workspace 7 silent, no_initial_focus on, focus_on_activate off
windowrule = match:class ^(steam_app_\d+)$, workspace 7 silent, no_initial_focus on, focus_on_activate off
# Godot-based Steam games (e.g. Slay the Spire 2) set their own window class instead of steam_app_*
windowrule = match:title ^(Godot)$, workspace 7 silent, no_initial_focus on, focus_on_activate off

# Steam game performance and idle inhibit - unpin so fullscreen keybind works
windowrule = match:class ^(steam_app_\d+)$, immediate on, opacity 1.0 override, no_blur on, idle_inhibit always, pin off
windowrule = match:class ^(gamescope)$, pin off
windowrule = match:title ^(Godot)$, immediate on, opacity 1.0 override, no_blur on, idle_inhibit always, pin off
{{ end }}

