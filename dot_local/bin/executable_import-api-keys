#!/bin/sh
# Import everything from the session-env keyring bucket into the
# systemd --user environment so GUI apps launched under Hyprland/uwsm
# inherit the vars.
#
# Enumeration is delegated to `list-session-env`; see that script for
# the bucket convention.

set -eu

list-session-env | while IFS= read -r kv; do
    [ -n "$kv" ] || continue
    name=${kv%%=*}
    value=${kv#*=}
    if [ -z "$name" ] || [ -z "$value" ]; then
        continue
    fi
    systemctl --user set-environment "$name=$value"
    echo "set  $name" >&2
done
