#!/usr/bin/env python3
"""notification-focus-proxy

Bring the sending app of a clicked notification to focus, generically.

Listens on the session bus as a monitor for org.freedesktop.Notifications
traffic. Correlates:

    Notify (method call, serial S) →   stores sender identity
    method return (reply_serial S)  →   learns notification id for that sender
    ActionInvoked(id, key) (signal) →   runs focus-sender with stored identity
    NotificationClosed(id, reason)  →   drops the mapping

On ActionInvoked we exec ~/.config/swaync/scripts/focus-sender.sh with
SWAYNC_APP_NAME and SWAYNC_DESKTOP_ENTRY env vars set, which already knows
how to find+raise the matching Hyprland window (handling special workspaces).

This intentionally does NOT consume the action — the originating app still
receives ActionInvoked on the bus and can route to the correct conversation/
thread/issue as usual. We're purely additive.
"""

from __future__ import annotations

import logging
import os
import subprocess
import sys
from typing import Optional

import gi

gi.require_version("Gio", "2.0")
gi.require_version("GLib", "2.0")
from gi.repository import Gio, GLib  # noqa: E402

FOCUS_SCRIPT = os.path.expanduser("~/.config/swaync/scripts/focus-sender.sh")

log = logging.getLogger("notification-focus-proxy")

# Pending Notify calls awaiting their reply (serial → identity dict).
pending: dict[int, dict] = {}
# Active notifications (id → identity dict).
active: dict[int, dict] = {}


def _extract_identity(body: GLib.Variant) -> dict:
    """Pull app_name + desktop-entry out of a Notify method-call body."""
    try:
        unpacked = body.unpack()
        app_name = unpacked[0] if len(unpacked) > 0 else None
        hints = unpacked[6] if len(unpacked) > 6 else {}
        desktop_entry = hints.get("desktop-entry") if isinstance(hints, dict) else None
    except Exception as e:  # pragma: no cover
        log.warning("failed to parse Notify body: %s", e)
        app_name = desktop_entry = None
    return {"app_name": app_name or "", "desktop_entry": desktop_entry or ""}


def _fire_focus(identity: dict) -> None:
    env = os.environ.copy()
    env["SWAYNC_APP_NAME"] = identity.get("app_name", "") or ""
    env["SWAYNC_DESKTOP_ENTRY"] = identity.get("desktop_entry", "") or ""
    if not (env["SWAYNC_APP_NAME"] or env["SWAYNC_DESKTOP_ENTRY"]):
        log.debug("empty identity, skipping focus")
        return
    log.info(
        "focus: app_name=%r desktop_entry=%r",
        env["SWAYNC_APP_NAME"],
        env["SWAYNC_DESKTOP_ENTRY"],
    )
    try:
        subprocess.Popen(
            [FOCUS_SCRIPT],
            env=env,
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            close_fds=True,
        )
    except FileNotFoundError:
        log.error("focus script not found: %s", FOCUS_SCRIPT)
    except Exception as e:
        log.error("failed to spawn focus script: %s", e)


def _on_message(
    conn: Gio.DBusConnection, message: Gio.DBusMessage, incoming: bool
) -> Optional[Gio.DBusMessage]:
    """Filter callback for every message on the bus."""
    log.debug("FILTER called incoming=%s", incoming)
    try:
        iface = message.get_interface() or ""
        member = message.get_member() or ""
        mtype = message.get_message_type()
        log.debug(
            "msg: incoming=%s type=%s iface=%s member=%s",
            incoming, mtype, iface, member,
        )
        if iface != "org.freedesktop.Notifications":
            return message

        if (
            mtype == Gio.DBusMessageType.METHOD_CALL
            and member == "Notify"
        ):
            body = message.get_body()
            serial = message.get_serial()
            identity = _extract_identity(body)
            log.info("Notify serial=%s identity=%s", serial, identity)
            pending[serial] = identity

        elif mtype == Gio.DBusMessageType.METHOD_RETURN:
            reply_serial = message.get_reply_serial()
            log.debug("METHOD_RETURN reply_serial=%s pending=%s", reply_serial, list(pending.keys()))
            identity = pending.pop(reply_serial, None)
            if identity is not None:
                try:
                    notif_id = message.get_body().unpack()[0]
                except Exception as e:
                    log.warning("failed to parse Notify reply: %s", e)
                    notif_id = None
                if isinstance(notif_id, int):
                    active[notif_id] = identity
                    log.info("tracked id=%s %s", notif_id, identity)

        elif mtype == Gio.DBusMessageType.SIGNAL and member == "ActionInvoked":
            try:
                notif_id, _key = message.get_body().unpack()[:2]
            except Exception:
                notif_id = None
            log.info("ActionInvoked id=%s tracked=%s", notif_id, notif_id in active)
            if notif_id in active:
                _fire_focus(active[notif_id])
            else:
                log.debug("ActionInvoked for unknown id=%s; active=%s", notif_id, list(active.keys()))

        elif mtype == Gio.DBusMessageType.SIGNAL and member == "NotificationClosed":
            try:
                notif_id = message.get_body().unpack()[0]
            except Exception:
                notif_id = None
            active.pop(notif_id, None)

    except Exception as e:  # pragma: no cover - never let the filter die
        log.exception("filter error: %s", e)

    # We're a passive observer: always pass the message through unchanged.
    return message


def main() -> int:
    logging.basicConfig(
        level=os.environ.get("LOG_LEVEL", "INFO").upper(),
        format="%(asctime)s %(levelname)s %(message)s",
    )

    bus = Gio.bus_get_sync(Gio.BusType.SESSION, None)
    if bus is None:
        log.error("could not get session bus")
        return 1

    # Become a passive monitor for the notification interface.
    match_rules = ["interface='org.freedesktop.Notifications'"]
    try:
        bus.call_sync(
            "org.freedesktop.DBus",
            "/org/freedesktop/DBus",
            "org.freedesktop.DBus.Monitoring",
            "BecomeMonitor",
            GLib.Variant("(asu)", (match_rules, 0)),
            None,
            Gio.DBusCallFlags.NONE,
            -1,
            None,
        )
    except GLib.Error as e:
        log.error("BecomeMonitor failed: %s", e)
        return 2

    bus.add_filter(_on_message)
    log.info("ready; watching org.freedesktop.Notifications")
    GLib.MainLoop().run()
    return 0


if __name__ == "__main__":
    sys.exit(main())
